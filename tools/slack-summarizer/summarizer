#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# summarizer — Unified CLI for Slack summary system
# ─────────────────────────────────────────────────────────────────────────────
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
[[ -f "$SCRIPT_DIR/config.env" ]] && source "$SCRIPT_DIR/config.env"
DATA_DIR="${DATA_DIR:-$SCRIPT_DIR}"

# PATH setup: ensure claude, python3, curl are available (critical for cron)
export HOME="${HOME:-$(eval echo ~)}"
NVM_LATEST="$HOME/.nvm/versions/node/$(ls -r "$HOME/.nvm/versions/node/" 2>/dev/null | head -1)/bin"
for p in "$NVM_LATEST" "$HOME/.asdf/shims" /opt/homebrew/bin /usr/local/bin; do
    [[ -d "$p" && ":$PATH:" != *":$p:"* ]] && export PATH="$p:$PATH"
done

# claude -p handles its own auth (reads from keychain).
# Make sure you've run: claude /login

# Export CHANNELS as comma-separated list for Python scripts
if [[ ${#CHANNELS[@]} -gt 0 ]] 2>/dev/null; then
    CSV=""
    for ch in "${CHANNELS[@]}"; do CSV="${CSV:+$CSV,}$ch"; done
    export CHANNELS_LIST="$CSV"
fi

# Export all config as env vars for Python
export DATA_DIR SLACK_PROXY_URL SLACK_PROXY_API_KEY MY_SLACK_USER_ID MY_SLACK_USER_NAME
export SLACK_WORKSPACE_URL SLACK_DM_CHANNEL PUBLISH_MODE PUBLISH_DIR
export MDNEST_SERVER MDNEST_NS STALE_DAYS DELETE_OLDER_THAN_DAYS

usage() {
    cat <<EOF
Usage: ./summarizer <command> [options]

Commands:
  sendSummary                        Poll → filter → summarize → send DM (background)
  redo                               Same as sendSummary but waits for completion (foreground)
  createReport [--no-send] [--output <path>]   Daily report from last 24h
  consolidate [--dry-run] [--delete-old]       Nightly thread consolidation
  check                              Validate config + connectivity
  list-channels [--raw]              Discover channel IDs from proxy
  help                               Show this message

Examples:
  ./summarizer check
  ./summarizer list-channels
  ./summarizer sendSummary
  ./summarizer createReport --no-send
  ./summarizer consolidate --delete-old
EOF
}

COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
    sendSummary)
        FILTERED=$(python3 "$SCRIPT_DIR/slack_poll.py")
        if [[ -n "$FILTERED" && -f "$FILTERED" ]]; then
            bash "$SCRIPT_DIR/summarize.sh" "$FILTERED" &
            echo "[$(date '+%Y-%m-%d %H:%M:%S')] Summarizer running (PID: $!)" >&2
        fi
        ;;
    createReport)
        exec bash "$SCRIPT_DIR/report.sh" "$@"
        ;;
    redo)
        # Re-poll and summarize (foreground, not backgrounded)
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Re-polling and summarizing..." >&2
        FILTERED=$(python3 "$SCRIPT_DIR/slack_poll.py")
        if [[ -n "$FILTERED" && -f "$FILTERED" ]]; then
            bash "$SCRIPT_DIR/summarize.sh" "$FILTERED"
        else
            echo "No new messages since last poll. Reset state to re-fetch:" >&2
            echo "  echo '{\"last_mention_ts\":\"0\",\"last_thread_ts\":\"0\",\"channels\":{}}' > \$DATA_DIR/state/last_poll.json" >&2
        fi
        ;;
    consolidate)
        exec bash "$SCRIPT_DIR/consolidate_run.sh" "$@"
        ;;
    check)
        exec python3 "$SCRIPT_DIR/check.py"
        ;;
    list-channels)
        exec python3 "$SCRIPT_DIR/list_channels.py" "$@"
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        echo "Unknown command: $COMMAND"
        usage
        exit 1
        ;;
esac
