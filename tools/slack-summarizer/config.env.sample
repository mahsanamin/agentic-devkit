# ─────────────────────────────────────────────────────────────────────────────
# config.env — Configuration for Slack Summarizer
#
# Copy this file to config.env and fill in your values:
#   cp config.env.sample config.env
#
# See setup.md for step-by-step instructions on finding each value.
# ─────────────────────────────────────────────────────────────────────────────

# ── Data Storage ─────────────────────────────────────────────────────────────
# Where raw polls, summaries, state, and logs are stored.
DATA_DIR="$HOME/.slack_summaries_data"

# ── Slack Proxy ──────────────────────────────────────────────────────────────
# Local Slack proxy endpoint and API key.
# The proxy wraps Slack API into compact JSON. See setup.md for details.
SLACK_PROXY_URL="https://localhost:8282"
SLACK_PROXY_API_KEY="your-proxy-api-key-here"

# ── Your Slack Identity ──────────────────────────────────────────────────────
# How to find: Slack profile → ... → Copy member ID
MY_SLACK_USER_ID="U0000000000"
MY_SLACK_USER_NAME="Your Name"

# ── Slack Workspace ──────────────────────────────────────────────────────────
# Used to generate permalink URLs in summaries.
SLACK_WORKSPACE_URL="https://your-workspace.slack.com"

# ── DM Channel ───────────────────────────────────────────────────────────────
# Where summaries are sent. This is your DM with yourself or Slackbot.
# How to find: open the DM → click name at top → scroll down → "Channel ID"
SLACK_DM_CHANNEL="D000000000"

# ── Channels to Monitor ──────────────────────────────────────────────────────
# How to find channel ID: open channel → click name at top → scroll to bottom
#
# Format: "CHANNEL_ID:friendly-name:TIER"
#   team  = Your team channels. Full detail, 8 messages per poll.
#   org   = Company-wide. Highlights only, 5 messages per poll.
#   leads = Leadership. Key decisions only, 5 messages per poll.
CHANNELS=(
    # --- Team channels (every message covered) ---
    # "C0XXXXXXX1:my-team-core:team"
    # "C0XXXXXXX2:my-team-product:team"

    # --- Org-wide channels (outages, announcements only) ---
    # "C0XXXXXXX3:general:org"
    # "C0XXXXXXX4:engineering:org"

    # --- Leadership channels (decisions, escalations) ---
    # "C0XXXXXXX5:eng-leads:leads"
)

# ── Publishing (Living Docs) ─────────────────────────────────────────────────
# Summaries are published as living docs that update with each poll/consolidation:
#   slack/latest.md            — Rolling briefing feed (per-poll)
#   slack/links-to-track.md    — Thread tracker (nightly)
#   slack/summaries.md         — Consolidated status (nightly)
#
# PUBLISH_MODE controls where these files go:
#   "local"   — Write to a local directory (default, no extra deps)
#   "mdnest"  — Publish via mdnest CLI (https://github.com/nichochar/mdnest)
#   "none"    — Skip publishing entirely
PUBLISH_MODE="local"

# For local mode: directory where published docs are written
PUBLISH_DIR="$DATA_DIR/published"

# For mdnest mode: server and namespace (leave empty if not using mdnest)
# Example: MDNEST_SERVER="@my-brain"  MDNEST_NS="my_workspace"
#   → publishes to @my-brain/my_workspace/slack/latest.md etc.
MDNEST_SERVER=""
MDNEST_NS=""

# ── Tuning ───────────────────────────────────────────────────────────────────
# Threads with no reply in this many days are pruned during consolidation
STALE_DAYS=30
# Old DM messages older than this are deleted with --delete-old
DELETE_OLDER_THAN_DAYS=7
