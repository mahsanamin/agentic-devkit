# Local settings
.claude/settings.local.json
**/.claude/settings.local.json

# macOS
.DS_Store

# IDE
.idea/
.vscode/

# Per-machine org profiles: local to each user/machine, never committed.
# Pattern matches <company>.<machine>.profile but NOT generic.profile.
# Samples (e.g. org.machine.profile.sample) are still tracked.
**/shell/*.*.profile
!**/shell/*.profile.sample

# Skill optimizer / eval runtime artifacts (regenerated, not source)
skills/*-workspace/
skills/**/opt-results/
skills/**/opt-report.html
skills/**/opt-loop.log

# Skill runtime state (watermarks, regenerated each run)
skills/**/state/

# Local-only maintenance skill: mirrors this public devkit from the private
# source repo and records the sync watermark. Never published (it names the
# private source paths/patterns by necessity, and the watermark is local state).
skills/a_r_l_devkit_sync/

# Tool runtime state + secrets
tools/**/state/
tools/**/config.env
tools/mdcf/mdcf
tools/mdcf/dist/

# Python bytecode
__pycache__/
*.pyc
