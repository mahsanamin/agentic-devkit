#!/bin/zsh
# Organization-specific profile template
#
# How to use:
#   1. Copy this file to: shell/<your-org>.<machine-type>.profile
#      Example: shell/acme.m1.profile
#   2. Set a_company_name='acme' and a_machine_type='m1' in your configs.profile
#   3. This file will be auto-loaded by generic.profile
#
# You can have multiple org profiles for different companies or machines:
#   shell/acme.m1.profile    (work laptop, Apple Silicon)
#   shell/acme.i7.profile    (work laptop, Intel)
#   shell/freelance.m1.profile (personal projects)

########################### Organization Exports ####
