#!/bin/bash
# Delete a branch after verifying it's merged into main
# Handles regular merges, squash merges, and "branch behind main" scenarios

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

FORCE_MODE=false
KEEP_REMOTE=false
BRANCH_NAME=""

# Parse arguments
while [[ "$#" -gt 0 ]]; do
    case $1 in
        -f|--force) FORCE_MODE=true ;;
        --keep-remote) KEEP_REMOTE=true ;;
        -h|--help)
            echo "Usage: a_g_branch_delete <branch-name> [options]"
            echo ""
            echo "Delete a branch after verifying it's merged into main."
            echo "Handles squash merges and branches that are behind main."
            echo ""
            echo "Arguments:"
            echo "  branch-name       Name of the branch to delete"
            echo ""
            echo "Options:"
            echo "  -f, --force       Skip merge verification"
            echo "  --keep-remote     Don't delete the remote branch"
            echo "  -h, --help        Show this help"
            echo ""
            echo "Examples:"
            echo "  a_g_branch_delete feature/auth"
            echo "  a_g_branch_delete hotfix-123 --keep-remote"
            exit 0
            ;;
        *) BRANCH_NAME="$1" ;;
    esac
    shift
done

if [ -z "$BRANCH_NAME" ]; then
    echo -e "${RED}Error: Branch name is required${NC}"
    echo "Usage: a_g_branch_delete <branch-name>"
    exit 1
fi

# Check if in a git repo
if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo -e "${RED}Error: Not in a git repository${NC}"
    exit 1
fi

# Check if branch exists
if ! git show-ref --verify --quiet "refs/heads/$BRANCH_NAME"; then
    echo -e "${RED}Error: Branch '$BRANCH_NAME' does not exist locally${NC}"
    echo ""
    echo "Local branches:"
    git branch | head -20
    exit 1
fi

# Check we're not on the branch we're trying to delete
CURRENT_BRANCH=$(git branch --show-current)
if [ "$CURRENT_BRANCH" = "$BRANCH_NAME" ]; then
    echo -e "${RED}Error: Cannot delete the branch you're currently on${NC}"
    echo "Switch to another branch first: git checkout main"
    exit 1
fi

# Protected branches
PROTECTED_BRANCHES="main master staging develop development prod production"
for protected in $PROTECTED_BRANCHES; do
    if [ "$BRANCH_NAME" = "$protected" ]; then
        echo -e "${RED}Error: Cannot delete protected branch '$BRANCH_NAME'${NC}"
        exit 1
    fi
done

# Determine main branch
if git show-ref --verify --quiet refs/heads/main; then
    MAIN_BRANCH="main"
elif git show-ref --verify --quiet refs/heads/master; then
    MAIN_BRANCH="master"
else
    echo -e "${RED}Error: Neither 'main' nor 'master' branch found${NC}"
    exit 1
fi

echo -e "${BLUE}Branch:${NC}       $BRANCH_NAME"
echo -e "${BLUE}Main branch:${NC}  $MAIN_BRANCH"
echo ""

# Fetch latest
echo "Fetching latest from remote..."
git fetch origin "$MAIN_BRANCH" --quiet 2>/dev/null || true

# Check if branch is merged into main
# Method 1: Check if branch is in merged list
MERGED_BRANCHES=$(git branch --merged "$MAIN_BRANCH" 2>/dev/null | sed 's/^[ *]*//')
IS_MERGED=false

if echo "$MERGED_BRANCHES" | grep -qx "$BRANCH_NAME"; then
    IS_MERGED=true
fi

# Method 2: Check against origin/main
if [ "$IS_MERGED" = false ]; then
    MERGED_REMOTE=$(git branch --merged "origin/$MAIN_BRANCH" 2>/dev/null | sed 's/^[ *]*//')
    if echo "$MERGED_REMOTE" | grep -qx "$BRANCH_NAME"; then
        IS_MERGED=true
    fi
fi

# Method 3: Check if branch tip is ancestor of main
if [ "$IS_MERGED" = false ]; then
    BRANCH_TIP=$(git rev-parse "$BRANCH_NAME" 2>/dev/null)
    MERGE_BASE=$(git merge-base "$BRANCH_NAME" "origin/$MAIN_BRANCH" 2>/dev/null)

    if [ "$BRANCH_TIP" = "$MERGE_BASE" ]; then
        IS_MERGED=true
    fi
fi

# Method 4: Check for squash merges - no code diff means changes are in main
if [ "$IS_MERGED" = false ]; then
    if git diff --quiet "origin/$MAIN_BRANCH"..."$BRANCH_NAME" 2>/dev/null; then
        echo -e "${YELLOW}(Detected as squash merge - no code differences)${NC}"
        IS_MERGED=true
    fi
fi

if [ "$IS_MERGED" = false ]; then
    # Check if branch is behind main (squash merged but main moved forward)
    MERGE_BASE=$(git merge-base "$BRANCH_NAME" "origin/$MAIN_BRANCH" 2>/dev/null)
    MAIN_CHANGES_SINCE_BASE=$(git rev-list "$MERGE_BASE".."origin/$MAIN_BRANCH" --count 2>/dev/null)

    if [ "$MAIN_CHANGES_SINCE_BASE" -gt 0 ] 2>/dev/null; then
        echo -e "${YELLOW}Branch may have been squash-merged, but main has moved forward.${NC}"
        echo ""
        echo -e "${BLUE}Your branch commits:${NC}"
        git log --oneline "$MERGE_BASE".."$BRANCH_NAME" | head -5
        echo ""

        # Try to extract ticket numbers from branch commits and verify in main
        TICKET_VERIFIED=false
        BRANCH_COMMITS=$(git log --oneline "$MERGE_BASE".."$BRANCH_NAME" 2>/dev/null)
        # Extract ticket patterns like PROJ-339, JIRA-123, ABC-1234, etc.
        TICKETS=$(echo "$BRANCH_COMMITS" | grep -oE '[A-Z]{2,}-[0-9]+' | sort -u)

        if [ -n "$TICKETS" ]; then
            echo -e "${BLUE}Checking if ticket(s) exist in main...${NC}"
            for ticket in $TICKETS; do
                FOUND_IN_MAIN=$(git log "origin/$MAIN_BRANCH" --oneline --grep="$ticket" 2>/dev/null | head -1)
                if [ -n "$FOUND_IN_MAIN" ]; then
                    echo -e "${GREEN}✓ Found '$ticket' in main:${NC} $FOUND_IN_MAIN"
                    TICKET_VERIFIED=true
                else
                    echo -e "${YELLOW}✗ '$ticket' not found in main's commit messages${NC}"
                fi
            done
            echo ""
        fi

        if [ "$TICKET_VERIFIED" = true ]; then
            echo -e "${GREEN}✓ Ticket verified in main - safe to delete${NC}"
            echo ""
            if [ "$FORCE_MODE" = false ]; then
                read -p "Proceed with deletion? (Y/n): " -n 1 -r
                echo
                # Default to Yes since ticket was verified
                if [[ $REPLY =~ ^[Nn]$ ]]; then
                    echo "Cancelled."
                    exit 0
                fi
            fi
        else
            echo -e "${BLUE}Main has ${MAIN_CHANGES_SINCE_BASE} new commits since your branch diverged.${NC}"
            echo ""
            echo -e "${BLUE}Differences between your branch and current main:${NC}"
            git diff "origin/$MAIN_BRANCH"..."$BRANCH_NAME" --stat | head -15
            echo ""

            if [ "$FORCE_MODE" = true ]; then
                echo -e "${YELLOW}--force specified, proceeding...${NC}"
            else
                echo -e "${YELLOW}Could not auto-verify. Options:${NC}"
                echo ""
                echo "  [r] Rebase onto main and check again (recommended)"
                echo "  [d] Delete anyway (if you're sure it was merged)"
                echo "  [c] Cancel"
                echo ""
                read -p "Choice [r/d/c]: " -n 1 -r
                echo

                if [[ $REPLY =~ ^[Rr]$ ]]; then
                    echo ""
                    echo "Rebasing $BRANCH_NAME onto origin/$MAIN_BRANCH..."

                    # Checkout the branch
                    git checkout "$BRANCH_NAME" 2>/dev/null

                    # Try to rebase
                    if git rebase "origin/$MAIN_BRANCH" 2>/dev/null; then
                        # Check if any commits remain after rebase
                        COMMITS_AFTER=$(git rev-list "origin/$MAIN_BRANCH"..HEAD --count 2>/dev/null)

                        # Go back to previous branch
                        git checkout - 2>/dev/null

                        if [ "$COMMITS_AFTER" = "0" ]; then
                            echo ""
                            echo -e "${GREEN}✓ After rebase: no unique commits remain${NC}"
                            echo -e "${GREEN}✓ Branch was squash-merged - safe to delete${NC}"
                            # Continue to deletion
                        else
                            echo ""
                            echo -e "${YELLOW}After rebase: $COMMITS_AFTER unique commit(s) remain${NC}"
                            echo "These commits are NOT in main."
                            echo ""
                            read -p "Still delete? (y/N): " -n 1 -r
                            echo
                            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                                echo "Cancelled."
                                exit 0
                            fi
                        fi
                    else
                        echo ""
                        echo -e "${RED}Rebase failed (conflicts). Aborting rebase...${NC}"
                        git rebase --abort 2>/dev/null
                        git checkout - 2>/dev/null
                        echo "Branch has conflicts with main - likely NOT merged."
                        exit 1
                    fi
                elif [[ $REPLY =~ ^[Dd]$ ]]; then
                    echo "Proceeding with deletion..."
                else
                    echo "Cancelled."
                    exit 0
                fi
            fi
        fi
    else
        echo -e "${RED}ERROR: Branch '$BRANCH_NAME' is NOT merged into $MAIN_BRANCH${NC}"
        echo ""
        echo "Unmerged commits:"
        git log --oneline "$MAIN_BRANCH..$BRANCH_NAME" | head -10
        echo ""

        if [ "$FORCE_MODE" = true ]; then
            echo -e "${YELLOW}--force specified, proceeding anyway...${NC}"
        else
            echo "Options:"
            echo "  1. Merge the branch first, then run this command again"
            echo "  2. Use --force to delete anyway (you will lose unmerged commits!)"
            exit 1
        fi
    fi
else
    echo -e "${GREEN}✓ Branch is merged into $MAIN_BRANCH${NC}"
fi

echo ""

# Confirm unless already confirmed above or force mode
if [ "$FORCE_MODE" = false ] && [ "$IS_MERGED" = true ]; then
    echo -e "${YELLOW}This will:${NC}"
    echo "  • Delete local branch: $BRANCH_NAME"
    if [ "$KEEP_REMOTE" = false ]; then
        echo "  • Delete remote branch: origin/$BRANCH_NAME (if exists)"
    fi
    echo ""
    read -p "Proceed? (y/N): " -n 1 -r
    echo

    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Cancelled."
        exit 0
    fi
fi

# Delete local branch
echo ""
echo "Deleting local branch..."
git branch -D "$BRANCH_NAME" 2>/dev/null && echo -e "${GREEN}✓ Local branch deleted${NC}" || echo -e "${YELLOW}  Local branch already deleted${NC}"

# Delete remote branch
if [ "$KEEP_REMOTE" = false ]; then
    echo "Deleting remote branch..."
    if git push origin --delete "$BRANCH_NAME" 2>/dev/null; then
        echo -e "${GREEN}✓ Remote branch deleted${NC}"
    else
        echo -e "${YELLOW}  Remote branch doesn't exist or already deleted${NC}"
    fi
fi

echo ""
echo -e "${GREEN}✓ Branch deleted successfully!${NC}"
