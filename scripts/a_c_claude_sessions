# --------------------------------------------------------------------------- #
# mdnest write (safe: literal temp file -> "$(cat)" -> verify)
# --------------------------------------------------------------------------- #
def write_mdnest(markdown, path):
    import tempfile
    with tempfile.NamedTemporaryFile("w", suffix=".md", delete=False) as tf:
        tf.write(markdown)
        tmp = tf.name
    try:
        # Does it already exist? Choose write vs create.
        exists = subprocess.run(
            ["bash", "-lc", f'mdnest read {path} >/dev/null 2>&1 && echo yes || echo no'],
            capture_output=True, text=True,
        ).stdout.strip()
        verb = "write" if exists == "yes" else "create"
        r = subprocess.run(
            ["bash", "-lc", f'mdnest {verb} {path} "$(cat {tmp})"'],
            capture_output=True, text=True,
        )
        if r.returncode != 0:
            print(f"mdnest {verb} failed:\n{r.stderr or r.stdout}", file=sys.stderr)
            return False
        # Verify: no escaped backticks survived, content is present.
        chk = subprocess.run(
            ["bash", "-lc", f'mdnest read {path}'],
            capture_output=True, text=True,
        ).stdout
        if "\\`" in chk:
            print("verify FAILED: escaped backticks found in stored note", file=sys.stderr)
            return False
        if "Running Sessions" not in chk:
            print("verify FAILED: heading missing from stored note", file=sys.stderr)
            return False
        print(f"mdnest {verb} OK -> {path}  ({len(chk)} bytes verified)")
        return True
    finally:
        try:
            os.unlink(tmp)
        except OSError:
            pass


# --------------------------------------------------------------------------- #
# Serve
# --------------------------------------------------------------------------- #
def _tailscale_ip():
    """Best-effort IPv4 Tailscale (100.64.0.0/10 CGNAT) address of this host."""
    for cmd in (["tailscale", "ip", "-4"],
                ["/Applications/Tailscale.app/Contents/MacOS/Tailscale", "ip", "-4"]):
        try:
            out = subprocess.run(cmd, capture_output=True, text=True, timeout=5).stdout
        except Exception:
            continue
        for tok in out.split():
            if re.match(r"100\.(6[4-9]|[7-9]\d|1[01]\d|12[0-7])\.", tok):
                return tok
    # Fallback: scan interfaces for a 100.x CGNAT address.
    try:
        out = subprocess.run(["ifconfig"], capture_output=True, text=True, timeout=5).stdout
        for line in out.splitlines():
            m = re.search(r"inet (100\.(?:6[4-9]|[7-9]\d|1[01]\d|12[0-7])\.\d+\.\d+)", line)
            if m:
                return m.group(1)
    except Exception:
        pass
    return None


_FAVICON_SVG = (
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32">'
    '<rect x="1" y="1" width="30" height="30" rx="7" fill="#0d1117" stroke="#30363d" stroke-width="2"/>'
    '<path d="M9 10 L15 16 L9 22" fill="none" stroke="#58a6ff" stroke-width="2.6" '
    'stroke-linecap="round" stroke-linejoin="round"/>'
    '<rect x="17" y="20" width="8" height="2.6" rx="1.3" fill="#7ee787"/>'
    '<circle cx="24.5" cy="8.5" r="3" fill="#1f7a3a" stroke="#7ee787" stroke-width="1"/>'
    '</svg>'
).encode()

_JSON_CACHE = {"t": 0.0, "body": None}
_JSON_LOCK = threading.Lock()
_ALLOW_KILL = False


def _cmd_of_pid(pid):
    try:
        return subprocess.run(["ps", "-o", "command=", "-p", str(pid)],
                              capture_output=True, text=True, timeout=5).stdout.strip()
    except Exception:
        return None


def _kill_session(key, force=False):
    """Signal the claude process(es) for a session. Safe: re-validates each pid is
    a live claude CLI process RIGHT NOW before signaling, and never touches this
    server's own process. `key` is a session id or a 'pids:1,2,3' key."""
    records = build_sessions()
    target = None
    for r in records:
        sid = r["meta"].get("session_id")
        rkey = sid or ("pids:" + ",".join(str(p["pid"]) for p in r["procs"]))
        if key == sid or key == rkey:
            target = r
            break
    if target is None:
        return {"ok": False, "error": "session not found (it may have already exited)"}

    sig = signal.SIGKILL if force else signal.SIGTERM
    me = os.getpid()
    killed, skipped = [], []
    for p in target["procs"]:
        pid = p["pid"]
        if pid == me:
            skipped.append({"pid": pid, "reason": "this is the dashboard server"})
            continue
        cmd = _cmd_of_pid(pid)
        if not cmd:
            skipped.append({"pid": pid, "reason": "already exited"})
            continue
        if not _is_real_claude(cmd):
            skipped.append({"pid": pid, "reason": "not a claude process (pid reused) - refused"})
            continue
        try:
            os.kill(pid, sig)
            killed.append(pid)
        except ProcessLookupError:
            skipped.append({"pid": pid, "reason": "already exited"})
        except PermissionError:
            skipped.append({"pid": pid, "reason": "permission denied"})
    # Make the next /json reflect the kill immediately.
    with _JSON_LOCK:
        _JSON_CACHE["body"] = None
    return {"ok": True, "signal": "SIGKILL" if force else "SIGTERM",
            "killed": killed, "skipped": skipped}


def _json_feed(ttl=4):
    """Cached JSON so rapid auto-refresh hits don't each trigger a full scan."""
    now = time.monotonic()
    with _JSON_LOCK:
        if _JSON_CACHE["body"] is not None and (now - _JSON_CACHE["t"]) < ttl:
            return _JSON_CACHE["body"]
        body = render_json(build_sessions()).encode()
        _JSON_CACHE.update(t=now, body=body)
        return body


def serve(host, port, refresh, allow_kill=False):
    from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer

    class Handler(BaseHTTPRequestHandler):
        protocol_version = "HTTP/1.1"

        def log_message(self, *a):
            pass

        def do_GET(self):
            try:
                path = self.path.split("?", 1)[0].rstrip("/")
                if path in ("/json", "/api"):
                    body = _json_feed()
                    ctype = "application/json"
                elif path in ("/favicon.ico", "/favicon.svg", "/favicon"):
                    body = _FAVICON_SVG
                    ctype = "image/svg+xml"
                else:
                    body = render_html(refresh).encode()
                    ctype = "text/html; charset=utf-8"
                self.send_response(200)
                self.send_header("Content-Type", ctype)
                self.send_header("Content-Length", str(len(body)))
                self.end_headers()
                self.wfile.write(body)
            except (BrokenPipeError, ConnectionResetError):
                pass

        def _reply(self, code, obj):
            body = json.dumps(obj).encode()
            self.send_response(code)
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)

        def do_POST(self):
            try:
                path = self.path.split("?", 1)[0].rstrip("/")
                if path != "/kill":
                    self._reply(404, {"ok": False, "error": "not found"})
                    return
                if not _ALLOW_KILL:
                    self._reply(403, {"ok": False,
                        "error": "kill is disabled; start the server with --allow-kill"})
                    return
                # CSRF defenses. (1) Require application/json: a cross-origin fetch
                # with this content-type triggers a CORS preflight the attacker's
                # page can't satisfy, and a form/"simple request" POST can't set it.
                ctype = self.headers.get("Content-Type", "").split(";")[0].strip().lower()
                if ctype != "application/json":
                    self._reply(415, {"ok": False,
                        "error": "Content-Type must be application/json"})
                    return
                # (2) If an Origin/Referer is present, it must match our own host.
                origin = self.headers.get("Origin") or self.headers.get("Referer", "")
                if origin:
                    host = self.headers.get("Host", "")
                    if urlparse(origin).netloc != host:
                        self._reply(403, {"ok": False,
                            "error": "cross-origin request refused"})
                        return
                n = int(self.headers.get("Content-Length") or 0)
                raw = self.rfile.read(n) if n else b"{}"
                try:
                    data = json.loads(raw or b"{}")
                except ValueError:
                    data = {}
                key = data.get("key")
                if not key:
                    self._reply(400, {"ok": False, "error": "missing 'key'"})
                    return
                self._reply(200, _kill_session(key, force=bool(data.get("force"))))
            except (BrokenPipeError, ConnectionResetError):
                pass
            except Exception as e:  # never crash the server on a bad request
                try:
                    self._reply(500, {"ok": False, "error": str(e)})
                except Exception:
                    pass

    global _ALLOW_KILL
    _ALLOW_KILL = bool(allow_kill)
    try:
        httpd = ThreadingHTTPServer((host, port), Handler)
        httpd.daemon_threads = True
    except OSError as e:
        print(f"error: cannot bind {host}:{port} -> {e}", file=sys.stderr)
        if host not in ("127.0.0.1", "0.0.0.0", "localhost"):
            print("  (is that address up on this machine? `tailscale ip -4` to check, "
                  "or use --bind 0.0.0.0)", file=sys.stderr)
        sys.exit(1)
    shown = "localhost" if host in ("127.0.0.1", "0.0.0.0") else host
    scope = ("all interfaces (LAN + tailnet + public)" if host == "0.0.0.0"
             else "this machine only" if host in ("127.0.0.1", "localhost")
             else "this address only (e.g. your tailnet)")
    print(f"Claude sessions dashboard at http://{shown}:{port}  (Ctrl-C to stop)", flush=True)
    print(f"  JSON feed at http://{shown}:{port}/json", flush=True)
    print(f"  bound to {host}:{port} - reachable from {scope}", flush=True)
    print(f"  kill endpoint: {'ENABLED (POST /kill)' if _ALLOW_KILL else 'disabled'}", flush=True)
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        print("\nstopped")


# --------------------------------------------------------------------------- #
# launchd self-install (portable: paths are read from THIS machine at run time)
# --------------------------------------------------------------------------- #
LAUNCH_AGENTS_DIR = os.path.join(HOME, "Library", "LaunchAgents")


def _agent_spec(kind, port, allow_kill=False):
    """(label, ProgramArguments, keepalive, start_interval, logfile) for a kind."""
    script = os.path.realpath(__file__)
    logs = os.path.join(HOME, "Library", "Logs")
    # Run the script directly (its #!/usr/bin/env python3 shebang + the PATH we
    # set below resolve python), so a later python upgrade does not strand a
    # pinned interpreter path.
    if kind == "web":
        args = [script, "--serve", str(port), "--tailscale"]
        if allow_kill:
            args.append("--allow-kill")
        return (
            "com.ahsan.claude-sessions-web",
            args,
            True, None,
            os.path.join(logs, "a_c_claude_sessions_web.launchd.log"),
        )
    if kind == "mdnest":
        return (
            "com.ahsan.claude-sessions",
            [script, "--write-mdnest"],
            False, 600,
            os.path.join(logs, "a_c_claude_sessions.launchd.log"),
        )
    raise ValueError(kind)


def _launchd_path_env():
    """A PATH that covers tailscale, mdnest, python, and the usual dirs, on any Mac."""
    parts = [
        "/usr/local/bin", "/opt/homebrew/bin",
        "/Applications/Tailscale.app/Contents/MacOS",
        os.path.dirname(sys.executable),
        "/usr/bin", "/bin", "/usr/sbin", "/sbin",
    ]
    seen, out = set(), []
    for p in parts:
        if p and p not in seen:
            seen.add(p)
            out.append(p)
    return ":".join(out)


def _plist_xml(label, args, keepalive, start_interval, logfile):
    def esc(s):
        return (str(s).replace("&", "&amp;").replace("<", "&lt;")
                .replace(">", "&gt;"))
    arg_xml = "\n".join(f"        <string>{esc(a)}</string>" for a in args)
    sched = ("    <key>KeepAlive</key>\n    <true/>\n" if keepalive else
             f"    <key>StartInterval</key>\n    <integer>{start_interval}</integer>\n")
    return f"""<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Generated by `a_c_claude_sessions --install-*-agent` on this machine.
     Do not hand-copy to another machine; run the install command there instead
     (paths below are specific to this host). -->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>{esc(label)}</string>
    <key>ProgramArguments</key>
    <array>
{arg_xml}
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>{esc(_launchd_path_env())}</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
{sched}    <key>StandardOutPath</key>
    <string>{esc(logfile)}</string>
    <key>StandardErrorPath</key>
    <string>{esc(logfile)}</string>
</dict>
</plist>
"""


def install_agent(kind, port=8787, allow_kill=False):
    label, args, keepalive, interval, logfile = _agent_spec(kind, port, allow_kill)
    if kind == "web" and not _tailscale_ip():
        print("warning: no Tailscale IP detected on this machine yet. The agent will "
              "keep retrying until Tailscale is up. Start Tailscale, or use "
              "`--serve --bind 0.0.0.0` for a non-tailnet run.", file=sys.stderr)
    os.makedirs(LAUNCH_AGENTS_DIR, exist_ok=True)
    dest = os.path.join(LAUNCH_AGENTS_DIR, label + ".plist")
    with open(dest, "w") as f:
        f.write(_plist_xml(label, args, keepalive, interval, logfile))
    subprocess.run(["launchctl", "unload", dest],
                   capture_output=True, text=True)
    r = subprocess.run(["launchctl", "load", dest], capture_output=True, text=True)
    if r.returncode != 0:
        print(f"launchctl load failed: {r.stderr or r.stdout}", file=sys.stderr)
        return False
    print(f"installed + loaded {label}")
    print(f"  plist:  {dest}")
    print(f"  script: {os.path.realpath(__file__)}")
    print(f"  log:    {logfile}")
    if kind == "web":
        ip = _tailscale_ip()
        where = f"http://{ip}:{port}" if ip else f"(tailnet IP):{port}"
        print(f"  serving on {where}  (tailnet only; JSON at /json)")
        print(f"  kill endpoint: {'ENABLED' if allow_kill else 'disabled'}")
    else:
        print(f"  refreshing {DEFAULT_MDNEST_PATH} every {interval//60} min")
    return True


def uninstall_agent(kind):
    label, *_ = _agent_spec(kind, 8787)
    dest = os.path.join(LAUNCH_AGENTS_DIR, label + ".plist")
    subprocess.run(["launchctl", "unload", dest], capture_output=True, text=True)
    existed = os.path.exists(dest)
    try:
        os.remove(dest)
    except OSError:
        pass
    print(f"uninstalled {label}" + ("" if existed else " (was not installed)"))
    return True


# --------------------------------------------------------------------------- #
def main():
    ap = argparse.ArgumentParser(
        description="Live dashboard of Claude Code sessions running on this machine.")
    g = ap.add_mutually_exclusive_group()
    g.add_argument("--print", action="store_true", help="print Markdown (default)")
    g.add_argument("--json", action="store_true", help="print JSON")
    g.add_argument("--write-mdnest", nargs="?", const=DEFAULT_MDNEST_PATH,
                   metavar="PATH", help=f"write Markdown to mdnest (default {DEFAULT_MDNEST_PATH})")
    g.add_argument("--serve", nargs="?", const=8787, type=int, metavar="PORT",
                   help="serve an auto-refreshing web page (default port 8787)")
    g.add_argument("--install-web-agent", nargs="?", const=8787, type=int, metavar="PORT",
                   help="generate + load a launchd agent (for THIS machine) that serves "
                        "the dashboard on the tailnet at boot (default port 8787)")
    g.add_argument("--install-mdnest-agent", action="store_true",
                   help="generate + load a launchd agent that refreshes the mdnest note every 10 min")
    g.add_argument("--uninstall-web-agent", action="store_true",
                   help="unload + remove the tailnet web launchd agent")
    g.add_argument("--uninstall-mdnest-agent", action="store_true",
                   help="unload + remove the mdnest-refresh launchd agent")
    ap.add_argument("--bind", metavar="ADDR", default="127.0.0.1",
                    help="serve bind address (default 127.0.0.1 = this machine only; "
                         "give a tailnet IP to expose on Tailscale, or 0.0.0.0 for all)")
    ap.add_argument("--tailscale", action="store_true",
                    help="bind --serve to this machine's Tailscale IP (auto-detected)")
    ap.add_argument("--allow-kill", action="store_true",
                    help="enable the POST /kill endpoint + the web Kill buttons "
                         "(off by default; anyone who can reach the page can then end sessions)")
    ap.add_argument("--find", metavar="QUERY",
                    help="search ALL sessions on disk (live + closed) and print the "
                         "resume command for each match, best/newest first")
    ap.add_argument("--all", action="store_true",
                    help="list every session on disk (live + closed), newest first")
    ap.add_argument("--limit", type=int, default=600,
                    help="cap the transcript scan to the N newest sessions (0 = no cap)")
    ap.add_argument("--top", type=int, default=12,
                    help="how many matches to show in --find/--all markdown (default 12)")
    ap.add_argument("--refresh", type=int, default=10, help="web auto-refresh seconds (default 10)")
    args = ap.parse_args()

    if args.install_web_agent is not None:
        sys.exit(0 if install_agent("web", args.install_web_agent, allow_kill=args.allow_kill) else 1)
    if args.install_mdnest_agent:
        sys.exit(0 if install_agent("mdnest") else 1)
    if args.uninstall_web_agent:
        sys.exit(0 if uninstall_agent("web") else 1)
    if args.uninstall_mdnest_agent:
        sys.exit(0 if uninstall_agent("mdnest") else 1)

    if args.serve is not None:
        host = args.bind
        if args.tailscale:
            host = _tailscale_ip()
            if not host:
                print("error: could not detect a Tailscale IP on this machine "
                      "(is Tailscale up? try `tailscale ip -4`)", file=sys.stderr)
                sys.exit(1)
        serve(host, args.serve, args.refresh, allow_kill=args.allow_kill)
        return
    if args.find is not None or args.all:
        query = "" if args.all else args.find
        records = search_sessions(query, limit=args.limit)
        if args.json:
            print(render_search_json(records, query, args.limit))
        else:
            print(render_search_markdown(records, query, args.limit, shown=args.top))
        return
    if args.write_mdnest is not None:
        records = build_sessions()
        ok = write_mdnest(render_markdown(records), args.write_mdnest)
        sys.exit(0 if ok else 1)

    records = build_sessions()
    if args.json:
        print(render_json(records))
    else:
        print(render_markdown(records))


if __name__ == "__main__":
    main()
