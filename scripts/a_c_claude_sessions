    navigator.clipboard.writeText(btn.getAttribute('data-copy')).then(function(){
      var t=btn.textContent; btn.textContent='Copied'; setTimeout(function(){btn.textContent=t;},1200); });
    return; }
  var tr = e.target.closest('tr.row'); if(!tr) return;
  var k = tr.getAttribute('data-k'); OPEN[k] = !OPEN[k]; render();
});
refresh(); setInterval(refresh, REFRESH);
</script>
