  var force = btn.getAttribute('data-force')==='1';
  var nm = btn.getAttribute('data-name')||'this session';
  var msg = (force?'FORCE KILL (SIGKILL)':'End (SIGTERM)')+' '+nm+'?\n\n'
    +'This signals the running claude process. Unsaved work in that session may be lost.';
  if(!window.confirm(msg)) return;
  btn.disabled = true; var old = btn.textContent; btn.textContent = 'Killing…';
