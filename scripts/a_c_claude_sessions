      if(!killed){ alert('Nothing killed ('+res.signal+'). '+
        ((res.skipped||[]).map(function(x){return x.pid+': '+x.reason;}).join('; ')||'')); }
    })
    .catch(function(){ alert('Kill request failed to reach the server.'); btn.disabled=false; btn.textContent=old; });
}
