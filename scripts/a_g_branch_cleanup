#!/bin/bash
# Delete all local branches that have been merged into main/master
# SAFE: Only deletes branches that `git branch --merged` confirms
# Usage: a_g_branch_cleanup [--dry-run] [--force] [--include-remote]

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

DRY_RUN=false
FORCE=false
INCLUDE_REMOTE=false

for arg in "$@"; do
    case $arg in
        --dry-run|-n) DRY_RUN=true ;;
        --force|-f) FORCE=true ;;
        --include-remote|-r) INCLUDE_REMOTE=true ;;
        --help|-h)
            echo "Usage: a_g_branch_cleanup [options]"
            echo ""
            echo "Delete local branches that are fully merged into main/master."
            echo "Only deletes branches confirmed by 'git branch --merged' (safe)."
            echo ""
            echo "Options:"
            echo "  --dry-run, -n        Show what would be deleted without deleting"
            echo "  --force, -f          Skip confirmation prompt"
            echo "  --include-remote, -r Also delete remote branches (opt-in)"
            echo "  --help, -h           Show this help"
            echo ""
            echo "For squash-merged branches, use a_g_branch_delete <branch> instead."
            exit 0
            ;;
    esac
done

# Check if in a git repo
if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo -e "${RED}Error: Not in a git repository${NC}"
    exit 1
fi

# Determine main branch (main or master)
if git show-ref --verify --quiet refs/heads/main; then
    MAIN_BRANCH="main"
elif git show-ref --verify --quiet refs/heads/master; then
    MAIN_BRANCH="master"
else
    echo -e "${RED}Error: Neither 'main' nor 'master' branch found${NC}"
    exit 1
fi

CURRENT_BRANCH=$(git branch --show-current)

echo -e "${BLUE}Main branch:${NC} $MAIN_BRANCH"
echo -e "${BLUE}Current branch:${NC} $CURRENT_BRANCH"
echo ""

# Fetch latest from remote
echo "Fetching latest from remote..."
git fetch --prune origin 2>/dev/null || true

# Protected branches that should never be deleted
PROTECTED_BRANCHES="main|master|staging|develop|development|prod|production"

# Get merged local branches (excluding protected and current)
# Use origin/$MAIN_BRANCH to catch branches merged into remote main
# Strip leading whitespace, *, + (recent checkout indicator)
LOCAL_MERGED=$(git branch --merged "origin/$MAIN_BRANCH" 2>/dev/null | grep -vE "^\*|^\+|^\s*($PROTECTED_BRANCHES)\s*$" | sed 's/^[ *+]*//' | sed 's/^[ ]*//' || true)

# Display results
echo -e "${GREEN}=== Local branches merged into $MAIN_BRANCH ===${NC}"
if [ -z "$LOCAL_MERGED" ]; then
    echo "  (none)"
else
    echo "$LOCAL_MERGED" | sed 's/^/  /'
fi

# Show remote info only if --include-remote
REMOTE_MERGED=""
if [ "$INCLUDE_REMOTE" = true ]; then
    REMOTE_MERGED=$(git branch -r --merged "origin/$MAIN_BRANCH" 2>/dev/null | grep -E "^\s*origin/" | grep -vE "origin/($PROTECTED_BRANCHES|HEAD)" | sed 's/^[ ]*//' || true)

    echo ""
    echo -e "${GREEN}=== Remote branches merged into $MAIN_BRANCH ===${NC}"
    if [ -z "$REMOTE_MERGED" ]; then
        echo "  (none)"
    else
        echo "$REMOTE_MERGED" | sed 's/^/  /'
    fi
fi

echo ""

if [ -z "$LOCAL_MERGED" ] && [ -z "$REMOTE_MERGED" ]; then
    echo "Nothing to clean up!"
    echo ""
    echo -e "${BLUE}Note: This only finds branches that git confirms as merged.${NC}"
    echo -e "${BLUE}For squash-merged branches, use: a_g_branch_delete <branch>${NC}"
    exit 0
fi

if [ "$DRY_RUN" = true ]; then
    echo "[Dry run] No branches were deleted."
    exit 0
fi

# Confirm unless --force
if [ "$FORCE" != true ]; then
    TOTAL=0
    if [ -n "$LOCAL_MERGED" ]; then
        LOCAL_COUNT=$(echo "$LOCAL_MERGED" | wc -l | tr -d ' ')
        TOTAL=$((TOTAL + LOCAL_COUNT))
    fi
    if [ -n "$REMOTE_MERGED" ]; then
        REMOTE_COUNT=$(echo "$REMOTE_MERGED" | wc -l | tr -d ' ')
        TOTAL=$((TOTAL + REMOTE_COUNT))
    fi

    read -p "Delete $TOTAL branch(es)? [y/N] " -n 1 -r
    echo ""
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Aborted."
        exit 0
    fi
fi

# Delete local branches
if [ -n "$LOCAL_MERGED" ]; then
    echo ""
    echo "Deleting local branches..."
    echo "$LOCAL_MERGED" | while read -r branch; do
        if [ -n "$branch" ]; then
            echo "  Deleting: $branch"
            git branch -d "$branch" 2>/dev/null || echo "    (failed - may have unmerged commits)"
        fi
    done
fi

# Delete remote branches only if explicitly requested
if [ "$INCLUDE_REMOTE" = true ] && [ -n "$REMOTE_MERGED" ]; then
    echo ""
    echo "Deleting remote branches..."
    echo "$REMOTE_MERGED" | while read -r branch; do
        if [ -n "$branch" ]; then
            remote_branch="${branch#origin/}"
            echo "  Deleting: origin/$remote_branch"
            git push origin --delete "$remote_branch" 2>/dev/null || echo "    (already deleted or protected)"
        fi
    done
fi

echo ""
echo -e "${GREEN}Cleanup complete!${NC}"
