#!/bin/bash
# NOTE: This script is sourced (not executed) by the wrapper in worktree.sh
# so that cd works. Use 'return' instead of 'exit' to avoid killing the terminal.
#
# Creates a worktree from an existing remote branch - typically a teammate's
# branch or a PR. Accepts either a PR number (resolved via gh CLI) or a
# branch name.
#
# The worktree lives under WorkTrees/{project}/review-{slug}/ and a local
# tracking branch named review-{slug} is created pointing at origin/{remote-branch}.
# Naming convention reserves "review-" prefix so these are visually distinct
# from your own feature worktrees.

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

INPUT=""
REMOTE="origin"

# Parse arguments
while [[ "$#" -gt 0 ]]; do
    case $1 in
        -r|--remote) REMOTE="$2"; shift ;;
        -h|--help)
            echo "Usage: a_g_worktree_review <pr-number-or-branch-name> [-r|--remote <remote>]"
            echo ""
            echo "Creates a worktree from an existing remote branch - typically for"
            echo "reviewing a teammate's work or a PR locally."
            echo ""
            echo "Arguments:"
            echo "  pr-number-or-branch-name   A PR number (e.g. 356) OR a remote branch name"
            echo "                             (e.g. feature/some-branch). PR numbers are resolved"
            echo "                             via 'gh pr view' to find the head branch."
            echo ""
            echo "Options:"
            echo "  -r, --remote <name>        Remote to fetch from (default: origin)"
            echo "  -h, --help                 Show this help message"
            echo ""
            echo "Examples:"
            echo "  a_g_worktree_review 356"
            echo "  a_g_worktree_review feature/teammate-branch"
            echo "  a_g_worktree_review fix/x -r upstream"
            return 0
            ;;
        *) INPUT="$1" ;;
    esac
    shift
done

if [ -z "$INPUT" ]; then
    echo -e "${RED}Error: PR number or branch name is required${NC}"
    echo "Usage: a_g_worktree_review <pr-number-or-branch-name>"
    return 1
fi

# Check if current directory is in a git repository
if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo -e "${RED}Error: Not in a git repository${NC}"
    return 1
fi

GIT_ROOT=$(git rev-parse --show-toplevel)
PROJECT_NAME=$(basename "$GIT_ROOT")

# Resolve INPUT to a remote branch. If it's all digits, treat as PR number.
REMOTE_BRANCH=""
PR_NUMBER=""
if [[ "$INPUT" =~ ^[0-9]+$ ]]; then
    PR_NUMBER="$INPUT"
    if ! command -v gh >/dev/null 2>&1; then
        echo -e "${RED}Error: '$INPUT' looks like a PR number but the 'gh' CLI is not installed.${NC}"
        echo "Either install gh (https://cli.github.com) or pass the branch name directly."
        return 1
    fi
    echo -e "${YELLOW}Resolving PR #$PR_NUMBER head branch via gh...${NC}"
    REMOTE_BRANCH=$(gh pr view "$PR_NUMBER" --json headRefName -q .headRefName 2>/dev/null)
    if [ -z "$REMOTE_BRANCH" ]; then
        echo -e "${RED}Error: Could not resolve PR #$PR_NUMBER head branch.${NC}"
        echo "Check that the PR exists and 'gh' is authenticated for this repo."
        return 1
    fi
    echo "  PR #$PR_NUMBER → branch: $REMOTE_BRANCH"
else
    REMOTE_BRANCH="$INPUT"
fi

# Slug for the local branch and worktree directory.
# For PR: review-pr-{N}. For branch: review-{branch-with-slashes-to-dashes}.
if [ -n "$PR_NUMBER" ]; then
    SLUG="review-pr-$PR_NUMBER"
else
    SLUG="review-${REMOTE_BRANCH//\//-}"
fi

LOCAL_BRANCH="$SLUG"
WORKTREE_DIR_NAME="$SLUG"
WORKTREES_DIR="$(dirname "$GIT_ROOT")/WorkTrees"
WORKTREE_PATH="$WORKTREES_DIR/$PROJECT_NAME/$WORKTREE_DIR_NAME"

# Fail fast if the worktree dir already exists
if [ -d "$WORKTREE_PATH" ]; then
    echo -e "${RED}Error: Worktree already exists at $WORKTREE_PATH${NC}"
    echo "Either cd to the existing one or remove it first with a_g_worktree_remove."
    return 1
fi

# Fetch the remote branch
echo -e "${YELLOW}Fetching $REMOTE/$REMOTE_BRANCH...${NC}"
if ! git fetch "$REMOTE" "$REMOTE_BRANCH" 2>&1; then
    echo -e "${RED}Error: Failed to fetch $REMOTE/$REMOTE_BRANCH${NC}"
    echo "Check the branch exists on $REMOTE."
    return 1
fi

# Verify the remote ref now exists locally as a remote-tracking branch
if ! git show-ref --verify --quiet "refs/remotes/$REMOTE/$REMOTE_BRANCH"; then
    echo -e "${RED}Error: $REMOTE/$REMOTE_BRANCH not found after fetch.${NC}"
    return 1
fi

# If the local SLUG branch already exists, we'll point this worktree at it
# rather than recreating. Otherwise create a new local branch tracking the remote.
USE_EXISTING_LOCAL=false
if git show-ref --verify --quiet "refs/heads/$LOCAL_BRANCH"; then
    echo -e "${YELLOW}Local branch '$LOCAL_BRANCH' already exists.${NC}"
    read -p "Use the existing local branch? (y/N): " -n 1 -r
    echo
    if [[ "$REPLY" =~ ^[Yy]$ ]]; then
        USE_EXISTING_LOCAL=true
    else
        echo "Cancelled."
        return 0
    fi
fi

# Show plan
echo -e "${BLUE}Creating review worktree:${NC}"
echo "  Project:        $PROJECT_NAME"
echo "  Remote:         $REMOTE/$REMOTE_BRANCH"
[ -n "$PR_NUMBER" ] && echo "  PR:             #$PR_NUMBER"
echo "  Local branch:   $LOCAL_BRANCH"
echo "  Directory:      $WORKTREE_DIR_NAME"
echo "  Path:           $WORKTREE_PATH"
echo ""

mkdir -p "$WORKTREES_DIR/$PROJECT_NAME"

if [ "$USE_EXISTING_LOCAL" = true ]; then
    git worktree add "$WORKTREE_PATH" "$LOCAL_BRANCH"
else
    git worktree add -b "$LOCAL_BRANCH" "$WORKTREE_PATH" "refs/remotes/$REMOTE/$REMOTE_BRANCH"
fi

if [ $? -ne 0 ]; then
    echo -e "${RED}Failed to create worktree${NC}"
    return 1
fi

echo ""
echo -e "${GREEN}✓ Review worktree created${NC}"

# Copy dotfiles from the main repo (matches a_g_worktree_init behaviour)
DOTFILES_COPIED=0
for dotfile in "$GIT_ROOT"/.*; do
    basename="$(basename "$dotfile")"
    if [[ "$basename" == "." || "$basename" == ".." || "$basename" == ".git" ]]; then
        continue
    fi
    cp -Rn "$dotfile" "$WORKTREE_PATH/" 2>/dev/null
    DOTFILES_COPIED=$((DOTFILES_COPIED + 1))
done
if [ $DOTFILES_COPIED -gt 0 ]; then
    echo -e "${GREEN}✓ Copied $DOTFILES_COPIED dotfile(s) to worktree${NC}"
fi
echo ""

# Auto-cd if sourced
if [[ "${BASH_SOURCE[0]}" != "${0}" ]] || [[ -n "$ZSH_EVAL_CONTEXT" && "$ZSH_EVAL_CONTEXT" =~ :file$ ]]; then
    cd "$WORKTREE_PATH" || return 1
    echo -e "${GREEN}✓ Changed to worktree directory${NC}"
else
    echo -e "${BLUE}To change to the worktree directory, run:${NC}"
    echo "  cd $WORKTREE_PATH"
    echo ""
    echo -e "${YELLOW}Tip: For auto-cd, source the script instead:${NC}"
    echo "  source a_g_worktree_review $INPUT"
fi

echo ""
echo -e "${BLUE}When done reviewing, remove the worktree with:${NC}"
echo "  a_g_worktree_remove $SLUG"
